{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "iRead Operation Events",
  "type": "object",
  "required": ["path", "count", "returned", "invalid_lines", "events"],
  "properties": {
    "path": {"type": "string"},
    "count": {"type": "integer", "minimum": 0},
    "returned": {"type": "integer", "minimum": 0},
    "invalid_lines": {"type": "integer", "minimum": 0},
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "protocol_version",
          "operation_id",
          "request_id",
          "command",
          "config_dir",
          "phase",
          "at"
        ],
        "properties": {
          "protocol_version": {"type": "integer", "minimum": 1},
          "operation_id": {"type": "string", "minLength": 1},
          "request_id": {"type": ["string", "null"]},
          "command": {"type": "string", "minLength": 1},
          "config_dir": {"type": "string", "minLength": 1},
          "phase": {"enum": ["started", "finished", "failed"]},
          "at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
